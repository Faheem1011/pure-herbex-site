# Copy to .env.local for local dev. On Vercel, set these in Project Settings → Environment Variables.
# Never commit .env or .env.local — they are gitignored.

# Inbox dashboard login (used by API auth — not exposed in client source)
INBOX_PASSWORD="your-strong-inbox-password"

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN="your-meta-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_APP_SECRET="your-meta-app-secret"

# Public URL for inbox + status API (Vercel deployment)
NEXT_PUBLIC_INBOX_URL="https://pure-herbex-site.vercel.app"

# Vercel KV (auto-injected on Vercel when KV is linked)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
