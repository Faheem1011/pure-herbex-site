# Copy to .env.local for local dev. On Vercel, set these in Project Settings → Environment Variables.
# Never commit .env or .env.local — they are gitignored.

# Inbox dashboard login (used by API auth — not exposed in client source)
# Rotate with: .\scripts\rotate-inbox-password.ps1
INBOX_PASSWORD="your-strong-inbox-password"

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN="your-meta-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_APP_SECRET="your-meta-app-secret"

# Public URL for inbox + status API (Vercel deployment)
NEXT_PUBLIC_INBOX_URL="https://pure-herbex-site-eight.vercel.app"

# Vercel KV / Upstash (kv_Herbex_new_Database3 on PureHerbex Vercel)
# KV_REST_API_URL=https://cuddly-poodle-102740.upstash.io
# KV_REST_API_TOKEN=

# Second WhatsApp line (US inbox at /inbox-us/)
WHATSAPP_PHONE_NUMBER_ID_2="1152353194626438"

# Vercel Cron — 24h window auto follow-up (main PK inbox only)
# Hobby plan cannot use vercel.json crons more than once/day — use a free external
# scheduler instead (e.g. cron-job.org) every 60–120 minutes (not 15 — burns KV quota):
#   GET https://pure-herbex-site-eight.vercel.app/api/cron/window-followup/
#   Header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="your-long-random-cron-secret"
# Set to "false" to pause auto follow-ups
# WINDOW_FOLLOWUP_ENABLED="false"

# Orders CRM → Google Sheets export (optional)
# 1) Create a Google Cloud project, enable Google Sheets API
# 2) Create a service account, download JSON key
# 3) Create a Google Sheet and share it with the service account email as Editor
# 4) Paste the full service account JSON below (single line on Vercel is fine)
GOOGLE_SHEETS_SPREADSHEET_ID="your-google-sheet-document-id"
GOOGLE_SHEETS_TAB="Orders"
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com"}'
